{
    "name": "easysystem/oneteam",
    "description": "Oneteam - Modern One Page Web Application",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "EasySystem",
            "email": "info@easysystem.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "vlucas/phpdotenv": "^5.4",
        "firebase/php-jwt": "^6.3",
        "ramsey/uuid": "^4.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "Oneteam\\": "backend/core/",
            "Oneteam\\Api\\": "backend/api/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "install-db": "php install/database-setup.php"
    }
}
